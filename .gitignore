# ──────────────────────────────────────────────────────────────
#  Quicklin .gitignore
# ──────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
sdist/

# Virtual environments
.env
.venv/
venv/
ENV/

# Testing & coverage
.pytest_cache/
.mypy_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Type stubs
.pyi

# ── Kotlin / JVM ─────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
.gradle/
build/
out/
.kotlin/

# ── IDE ───────────────────────────────────────────────────────
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Quicklin ──────────────────────────────────────────────────
# Uncomment the line below to ignore generated .kt files:
# *.kt
